# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CLICKSTREAM=clickstream
KAFKA_TOPIC_ORDERS=orders
KAFKA_TOPIC_USERS=users

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=shopstream

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shopstream
POSTGRES_USER=shopstream
POSTGRES_PASSWORD=

# Airflow
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://shopstream:<password>@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=

# Spark
SPARK_MASTER=local[*]
DELTA_LAKE_VERSION=3.1.0

# App
ENV=development
LOG_LEVEL=INFO
